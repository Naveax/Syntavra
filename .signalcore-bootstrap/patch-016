+def compile_one_round_trip(task: RobloxTaskState, capsule: ContextCapsule, workflow: WorkflowDAG) -> dict[str, object]:
+    safe = (
+        task.risk_level in {RiskLevel.R0, RiskLevel.R1, RiskLevel.R2}
+        and not task.ambiguities
+        and len(workflow.nodes) <= 6
+        and capsule.total_tokens <= 6000
+    )
+    return {
+        "understanding": {
+            "goal": task.user_objective,
+            "targets": list(task.resolved_targets or task.selected_instances),
+            "constraints": dict(task.constraints),
+            "assumptions": list(task.assumptions),
+        },
+        "selectedRecipe": None,
+        "executionPlan": [node.node_id for node in workflow.nodes],
+        "patches": [],
+        "toolCalls": [tool for tool in capsule.tool_definitions],
+        "acceptanceTests": list(task.acceptance_criteria),
+        "riskFlags": [task.risk_level.value] if task.risk_level != RiskLevel.R0 else [],
+        "requiresApproval": not safe,
+        "oneRoundTripAllowed": safe,
+    }
+
