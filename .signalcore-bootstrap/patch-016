+def build_repair_capsule(
+    *,
+    task: RobloxTaskState,
+    failed_acceptance_test: str,
+    failure_class: str,
+    new_error: Mapping[str, object],
+    relevant_patch: Mapping[str, object],
+    relevant_code_range: Mapping[str, object],
+    changed_evidence: Iterable[str],
+    unchanged_evidence: Iterable[str],
+    previous_attempts: int,
+    maximum_attempts: int,
+) -> RepairCapsule:
+    if previous_attempts >= maximum_attempts:
+        raise ValidationFailedError("repair budget exhausted")
+    return RepairCapsule(
+        task_goal=task.user_objective,
+        failed_acceptance_test=failed_acceptance_test,
+        failure_class=failure_class,
+        new_error=dict(new_error),
+        relevant_patch=dict(relevant_patch),
+        relevant_code_range=dict(relevant_code_range),
+        changed_evidence=tuple(dict.fromkeys(map(str, changed_evidence))),
+        unchanged_evidence_references=tuple(dict.fromkeys(map(str, unchanged_evidence))),
+        repair_constraints=("patch only failed scope", "do not resend full project", "preserve verified behavior"),
+        previous_attempts=previous_attempts,
+    )
+
+
+def required_cross_validators(capabilities: Iterable[str]) -> tuple[str, ...]:
+    mapping = {
+        "LUAU_PATCH": ("luau_static_validator", "runtime_validator"),
+        "LUAU_CREATE": ("luau_static_validator", "runtime_validator"),
+        "ASSET_IMPORT": ("asset_security_validator", "asset_geometry_validator"),
+        "ANIMATION_ENGINE": ("animation_metrics_validator", "visual_review_validator"),
+        "BLENDER_WORKER": ("blender_import_validator", "rig_validator"),
+        "DATASTORE_MIGRATION_LAB": ("migration_validator", "rollback_validator"),
+        "CINEMATIC_ENGINE": ("camera_collision_validator", "visual_review_validator", "performance_validator"),
+    }
+    return tuple(dict.fromkeys(item for capability in capabilities for item in mapping.get(capability, ())))
+
+
+def validate_cross_engine(
+    producer_engine: str,
+    validator_results: Mapping[str, bool],
+    required_validators: Iterable[str],
+) -> bool:
+    required = tuple(dict.fromkeys(map(str, required_validators)))
+    if not required:
+        return True
+    if producer_engine in required:
+        raise ValidationFailedError("producer cannot be its sole validator")
+    missing = [validator for validator in required if validator_results.get(validator) is not True]
+    if missing:
+        raise ValidationFailedError("cross-engine validation failed: " + ", ".join(missing))
+    return True
+
