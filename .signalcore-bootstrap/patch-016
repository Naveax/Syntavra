ot_hash != project_snapshot_hash:
+            mismatches.append("project")
+        if dict(checkpoint.engine_versions) != dict(engine_versions):
+            mismatches.append("engine_versions")
+        if dict(checkpoint.model_versions) != dict(model_versions):
+            mismatches.append("model_versions")
+        if set(checkpoint.evidence_snapshot) != set(evidence_snapshot):
+            mismatches.append("evidence")
+        if checkpoint.capability_graph_version != capability_graph_version:
+            mismatches.append("capability_graph")
+        if checkpoint.profile_schema_version != profile_schema_version:
+            mismatches.append("profile_schema")
+        if mismatches:
+            raise CheckpointInvalidError("incompatible checkpoint: " + ", ".join(mismatches))
+
