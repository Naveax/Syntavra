EDACTED_SECRET]", value)
+            redactions += count
+        if for_cloud:
+            value, count = WINDOWS_PATH.subn("[REDACTED_LOCAL_PATH]", value)
+            redactions += count
+            value, count = PRIVATE_PATH.subn("[REDACTED_LOCAL_PATH]", value)
+            redactions += count
+        if trust_level not in self.TRUSTED_INSTRUCTION_CLASSES:
+            lines: list[str] = []
+            for line in value.splitlines():
+                if INJECTION.search(line):
+                    quarantined += 1
+                    lines.append("[QUARANTINED_EXTERNAL_DIRECTIVE] " + line)
+                else:
+                    lines.append(line)
+            value = "\n".join(lines)
+        if for_cloud and not self.config.send_minimal_code and self.config.allow_full_project_cloud_upload:
+            raise PolicyBlockedError("full project cloud upload is forbidden by profile policy")
+        return value, {"redactions": redactions, "quarantined_directives": quarantined, "trusted_instruction_source": trust_level in self.TRUSTED_INSTRUCTION_CLASSES}
+
+    def authorize_instruction(self, trust_level: str) -> None:
+        if trust_level not in self.TRUSTED_INSTRUCTION_CLASSES:
+            raise PolicyBlockedError(f"{trust_level} is data, not an instruction source")
+
+
+class TelemetryStore:
+    def __init__(self, path: str | Path) -> None:
+        self.path = Path(path).expanduser().resolve(strict=False)
+        self.path.parent.mkdir(parents=True, exist_ok=True)
+        with closing(self._connect()) as connection:
+            connection.executescript(
+                """
+                CREATE TABLE IF NOT EXISTS task_telemetry(
+                    task_id TEXT PRIMARY KEY,
+                    payload_json TEXT NOT NULL,
+                    created_at REAL NOT NULL
+                );
+                CREATE TABLE IF NOT EXISTS traces(
+                    trace_id TEXT PRIMARY KEY,
+                    payload_json TEXT NOT NULL,
+                    created_at REAL NOT NULL
+                );
+                """
+            )
+            connection.commit()
+
+    def _connect(self) -> sqlite3.Connection:
+        connection = sqlite3.connect(self.path, timeout=15)
+        connection.execute("PRAGMA journal_mode=WAL")
+        connection.execute("PRAGMA busy_timeout=15000")
+        return connection
+
+    def record(self, telemetry: TelemetryRecord) -> None:
+        payload = asdict(telemetry)
+        payload["risk_level"] = telemetry.risk_level.value
+        payload["final_status"] = telemetry.final_status.value
+        with closing(self._connect()) as connection:
+            connection.execute(
+                "INSERT OR REPLACE INTO task_telemetry VALUES(?,?,?)",
+                (telemetry.task_id, json.dumps(payload, sort_keys=True), time.time()),
+            )
+            connection.commit()
+
+    def record_trace(self, trace: OrchestrationTrace) -> None:
+        payload = asdict(trace)
+        with closing(self._connect()) as connection:
+            connection.execute(
+                "INSERT OR REPLACE INTO traces VALUES(?,?,?)",
+                (trace.trace_id, json.dumps(payload, sort_keys=True), time.time()),
+            )
+            connection.commit()
+
+    def read_trace(self, trace_id: str) -> OrchestrationTrace:
+        with closing(self._connect()) as connection:
+            row = connection.execute("SELECT payload_json FROM traces WHERE trace_id=?", (trace_id,)).fetchone()
+        if not row:
+            raise KeyError(trace_id)
+        value = json.loads(row[0])
+        return OrchestrationTrace(
+            trace_id=value["trace_id"],
+            task_state=value["task_state"],
+            capability_resolution=value["capability_resolution"],
+            engine_selection=value["engine_selection"],
+            model_selection=value["model_selection"],
+            evidence_selection=tuple(value["evidence_selection"]),
+            context_capsule_hash=value["context_capsule_hash"],
+            tool_schemas=tuple(value["tool_schemas"]),
+            workflow_hash=value["workflow_hash"],
+            budgets=value["budgets"],
+            tests=tuple(value["tests"]),
+            repairs=tuple(value["repairs"]),
+            commits=tuple(value["commits"]),
+            rollbacks=tuple(value["rollbacks"]),
+            versions=value["versions"],
+        )
+
+    @staticmethod
+    def validate_replay(trace: OrchestrationTrace, current_versions: Mapping[str, str]) -> None:
+        mismatches = [key for key, value in trace.versions.items() if current_versions.get(key) != value]
+        if mismatches:
+            raise PolicyBlockedError("replay version mismatch: " + ", ".join(mismatches))
+
+
+def make_trace(
+    *,
+    task_state: Mapping[str, Any],
+    capability_resolution: Mapping[str, Any],
+    engine_selection: Mapping[str, Any],
+    model_selection: Mapping[str, Any],
+    evidence_selection: Iterable[str],
+    context_capsule: Mapping[str, Any],
+    tool_schemas: Iterable[str],
+    workflow: Mapping[str, Any],
+    budgets: Mapping[str, Any],
+    tests: Iterable[str],
+    repairs: Iterable[str],
+    commits: Iterable[str],
+    rollbacks: Iterable[str],
+    versions: Mapping[str, str],
+) -> OrchestrationTrace:
+    context_hash = hashlib.sha256(json.dumps(context_capsule, sort_keys=True, default=str).encode()).hexdigest()
+    workflow_hash = hashlib.sha256(json.dumps(workflow, sort_keys=True, default=str).encode()).hexdigest()
+    trace_id = hashlib.sha256((str(task_state.get("task_id", "")) + context_hash + workflow_hash).encode()).hexdigest()[:24]
+    return OrchestrationTrace(
+        trace_id=trace_id,
+        task_state=dict(task_state),
+        capability_resolution=dict(capability_resolution),
+        engine_selection=dict(engine_selection),
+        model_selection=dict(model_selection),
+        evidence_selection=tuple(evidence_selection),
+        context_capsule_hash=context_hash,
+        tool_schemas=tuple(tool_schemas),
+        workflow_hash=workflow_hash,
+        budgets=dict(budgets),
+        tests=tuple(tests),
+        repairs=tuple(repairs),
+        commits=tuple(commits),
+        rollbacks=tuple(rollbacks),
+        versions=dict(versions),
+    )
+
+
+class AdaptivePolicyGate:
+    """Validation-only gate. It cannot mutate policy until telemetry is stable."""
+
+    def __init__(self, minimum_verified_tasks: int = 1000) -> None:
+        self.minimum_verified_tasks = minimum_verified_tasks
+
+    def allow_learning(self, *, verified_tasks: int, unsafe_executions: int, stale_evidence_executions: int, prompt_injection_executions: int) -> bool:
+        return (
+            verified_tasks >= self.minimum_verified_tasks
+            and unsafe_executions == 0
+            and stale_evidence_executions == 0
+            and prompt_injection_executions == 0
+        )
+
+    def immutable_invariants(self) -> tuple[str, ...]:
+        return (
+            "ambiguity_gate",
+            "risk_gate",
+            "certification_gate",
+            "sandbox_requirement",
+            "cross_engine_validation",
+            "privacy_firewall",
+            "human_approval",
+        )
