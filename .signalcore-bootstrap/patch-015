+class ModelResponseValidator:
+    REQUIRED_KEYS = frozenset({"understanding", "executionPlan", "toolCalls", "acceptanceTests", "riskFlags", "requiresApproval"})
+
+    @classmethod
+    def validate(cls, model: ModelSpec, response: Mapping[str, Any]) -> Mapping[str, Any]:
+        if response.get("timedOut") is True:
+            raise ValidationFailedError(f"model {model.model_id} timed out")
+        if not model.supports_structured_output:
+            raise ValidationFailedError(f"model {model.model_id} is not certified for structured output")
+        missing = cls.REQUIRED_KEYS - set(response)
+        if missing:
+            raise ValidationFailedError("model response missing: " + ", ".join(sorted(missing)))
+        if not isinstance(response.get("executionPlan"), list) or not isinstance(response.get("toolCalls"), list):
+            raise ValidationFailedError("model response plan/toolCalls must be lists")
+        if not isinstance(response.get("requiresApproval"), bool):
+            raise ValidationFailedError("requiresApproval must be boolean")
+        # Round-trip proves JSON serializability and rejects opaque Python objects.
+        try:
+            json.loads(json.dumps(response, ensure_ascii=False, sort_keys=True))
+        except (TypeError, ValueError) as exc:
+            raise ValidationFailedError("model response is not JSON serializable") from exc
+        return response
+
+
+class EngineResponseValidator:
+    @staticmethod
+    def validate(
+        engine: EngineSpec,
+        capability: str,
+        response: Mapping[str, Any],
+        *,
+        firewall: PrivacyFirewall | None = None,
+    ) -> ValidatedEngineResult:
+        if response.get("timedOut") is True:
+            raise ValidationFailedError(f"engine {engine.engine_id} timed out")
+        if capability not in engine.capabilities:
+            raise ValidationFailedError(f"engine {engine.engine_id} did not declare {capability}")
+        if str(response.get("engineId", "")) != engine.engine_id:
+            raise ValidationFailedError("engine response identity mismatch")
+        if str(response.get("engineVersion", "")) != engine.version:
+            raise ValidationFailedError("engine response version mismatch")
+        if str(response.get("capability", "")) != capability:
+            raise ValidationFailedError("engine response capability mismatch")
+        status = str(response.get("status", ""))
+        if status not in {"SUCCEEDED", "FAILED", "BLOCKED"}:
+            raise ValidationFailedError("invalid engine response status")
+        payload = response.get("payload", {})
+        if not isinstance(payload, Mapping):
+            raise ValidationFailedError("engine payload must be an object")
+        canonical = json.dumps(payload, ensure_ascii=False, sort_keys=True, separators=(",", ":"), default=str)
+        if firewall is not None:
+            firewall.sanitize(canonical, trust_level="GENERATED_ARTIFACT", for_cloud=False)
+        supplied_hash = str(response.get("artifactHash", ""))
+        calculated_hash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
+        if supplied_hash and supplied_hash != calculated_hash:
+            raise ValidationFailedError("engine artifact hash mismatch")
+        validators = response.get("validatorResults", {})
+        if not isinstance(validators, Mapping) or any(not isinstance(value, bool) for value in validators.values()):
+            raise ValidationFailedError("validatorResults must map names to booleans")
+        evidence = response.get("evidenceReferences", ())
+        if not isinstance(evidence, (list, tuple)):
+            raise ValidationFailedError("evidenceReferences must be a list")
+        return ValidatedEngineResult(
+            engine.engine_id,
+            engine.version,
+            capability,
+            status,
+            calculated_hash,
+            tuple(map(str, evidence)),
+            {str(key): bool(value) for key, value in validators.items()},
+            dict(payload),
+        )
