+class WorkflowPlanner:
+    def __init__(self, schema_version: int = 2) -> None:
+        self.schema_version = schema_version
+
+    def plan(
+        self,
+        task: RobloxTaskState,
+        route: RoutePlan,
+        *,
+        validators_by_capability: Mapping[str, Sequence[str]] | None = None,
+    ) -> WorkflowDAG:
+        validators_by_capability = validators_by_capability or {}
+        primary = next((item for item in task.task_classes if item in WORKFLOW_TEMPLATES), task.task_classes[0])
+        template = WORKFLOW_TEMPLATES.get(primary)
+        if template is None:
+            template = tuple((f"step_{index+1}_{capability.casefold()}", (capability,), (() if index == 0 else (f"step_{index}_{task.required_capabilities[index-1].casefold()}",))) for index, capability in enumerate(task.required_capabilities))
+        nodes: list[WorkflowNode] = []
+        for index, (name, capabilities, dependencies) in enumerate(template):
+            engine = _engine_for_capabilities(capabilities, route.engine_ids)
+            acceptance = tuple(dict.fromkeys(
+                test for capability in capabilities for test in validators_by_capability.get(capability, ())
+            )) or (f"{name}_verified",)
+            risk = task.risk_level
+            sandbox = max((task.sandbox_level, route.sandbox_level), key=_sandbox_rank)
+            approval = name == "human_approval" or (index == len(template) - 1 and risk in {RiskLevel.R3, RiskLevel.R4, RiskLevel.R5})
+            nodes.append(WorkflowNode(
+                node_id=name,
+                task_class=primary,
+                required_capabilities=tuple(capabilities),
+                selected_engine=engine,
+                selected_model=route.model_id,
+                dependencies=tuple(dependencies),
+                inputs=("context_capsule",),
+                outputs=(f"artifact:{name}",),
+                acceptance_tests=acceptance,
+                risk_level=risk,
+                sandbox_level=sandbox,
+                token_budget={"input": 1200 if route.deterministic else 3000, "output": 0 if route.deterministic else 1800},
+                resource_budget={"wall_time_seconds": 300, "gpu_time_ms": 120_000},
+                retry_policy={"maximum_attempts": 1 if approval else 2, "same_failure_stop": 2},
+                rollback_policy={"required": risk in {RiskLevel.R3, RiskLevel.R4, RiskLevel.R5}, "checkpoint_before": True},
+                human_approval=approval,
+            ))
+        self._validate_dag(nodes)
+        digest = hashlib.sha256((task.task_id + "\0" + "\0".join(node.node_id for node in nodes)).encode()).hexdigest()[:24]
+        return WorkflowDAG(f"wf-{digest}", task.task_id, tuple(nodes), time.time(), self.schema_version)
+
+
+    @staticmethod
+    def _validate_dag(nodes: Sequence[WorkflowNode]) -> None:
+        ids = {node.node_id for node in nodes}
+        if len(ids) != len(nodes):
+            raise ValidationFailedError("duplicate workflow node")
+        for node in nodes:
+            unknown = set(node.dependencies) - ids
+            if unknown:
+                raise ValidationFailedError(f"unknown dependencies for {node.node_id}: {sorted(unknown)}")
+        visited: set[str] = set()
+        visiting: set[str] = set()
+        by_id = {node.node_id: node for node in nodes}
+
+        def visit(node_id: str) -> None:
+            if node_id in visited:
+                return
+            if node_id in visiting:
+                raise ValidationFailedError("workflow cycle detected")
+            visiting.add(node_id)
+            for dependency in by_id[node_id].dependencies:
+                visit(dependency)
+            visiting.remove(node_id)
+            visited.add(node_id)
+
+        for node_id in by_id:
+            visit(node_id)
+
+    @staticmethod
+    def ready_nodes(workflow: WorkflowDAG, completed: Iterable[str]) -> tuple[WorkflowNode, ...]:
+        completed_set = set(completed)
+        return tuple(node for node in workflow.nodes if node.node_id not in completed_set and set(node.dependencies).issubset(completed_set))
