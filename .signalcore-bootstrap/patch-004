                  "ordinary": ordinary,
+                })
+
+    summaries: dict[str, dict[str, object]] = {}
+    for name, values in rows.items():
+        summaries[name] = {
+            "cases": len(values),
+            "verified_success": statistics.mean(float(item["verified"]) for item in values),
+            "unsafe_execution": sum(int(item["unsafe"]) for item in values),
+            "cloud_requests": sum(int(item["cloud_requests"]) for item in values),
+            "local_requests": sum(int(item["local_requests"]) for item in values),
+            "engine_calls": sum(int(item["engine_calls"]) for item in values),
+            "fresh_cloud_tokens": sum(int(item["fresh_cloud_tokens"]) for item in values),
+            "average_selected_tokens": statistics.mean(float(item["selected_tokens"]) for item in values),
+            "cache_hit_rate": statistics.mean(float(item["cache_hit"]) for item in values),
+            "deterministic_rate": statistics.mean(float(item["deterministic"]) for item in values),
+            "p50_orchestration_ms": statistics.median(float(item["wall_time_ms"]) for item in values),
+            "p95_orchestration_ms": _percentile([float(item["wall_time_ms"]) for item in values], .95),
+        }
+
+    d_rows = rows["D_roblox_full"]
+    confusion = {expected: {actual: 0 for actual in ROUTE_BUCKETS} for expected in ROUTE_BUCKETS}
+    for row in d_rows:
+        confusion[str(row["expected_route"])][str(row["route_bucket"])] += 1
+    routing_accuracy = statistics.mean(float(row["expected_route"] == row["route_bucket"]) for row in d_rows)
+    family_report: dict[str, dict[str, object]] = {}
+    for category in sorted({str(row["category"]) for row in d_rows}):
+        subset = [row for row in d_rows if row["category"] == category]
+        family_report[category] = {
+            "cases": len(subset),
+            "verified_success": statistics.mean(float(row["verified"]) for row in subset),
+            "cloud_requests": sum(int(row["cloud_requests"]) for row in subset),
+            "average_selected_tokens": statistics.mean(float(row["selected_tokens"]) for row in subset),
+            "cache_hit_rate": statistics.mean(float(row["cache_hit"]) for row in subset),
+            "p95_orchestration_ms": _percentile([float(row["wall_time_ms"]) for row in subset], .95),
+        }
+    ordinary_rows = [row for row in d_rows if bool(row["ordinary"])]
+    ordinary_cloud_per_1000 = 1000 * sum(int(row["cloud_requests"]) for row in ordinary_rows) / max(1, len(ordinary_rows))
+    deterministic_rows = [row for row in d_rows if bool(row["deterministic"])]
+    engine_certifications = sum(len(value) for value in matrix.to_dict().values())
+    model_certifications = sum(len(model.role_certifications) for model in models.models.values())
+    targets = {
+        "ordinary_cloud_requests_per_1000_le_180": ordinary_cloud_per_1000 <= 180,
+        "deterministic_p50_le_20_ms": statistics.median(float(row["wall_time_ms"]) for row in deterministic_rows) <= 20 if deterministic_rows else False,
+        "deterministic_p95_le_50_ms": _percentile([float(row["wall_time_ms"]) for row in deterministic_rows], .95) <= 50 if deterministic_rows else False,
+        "unnecessary_cloud_escalation_below_5_percent": statistics.mean(float(row["route_bucket"].startswith("CLOUD") and row["expected_route"] == "LOCAL") for row in ordinary_rows) < .05,
+    }
+    release_gates = {
+        "D_success_not_lower_than_A": summaries["D_roblox_full"]["verified_success"] >= summaries["A_external_without_signalcore"]["verified_success"],
+        "D_unsafe_execution_zero": summaries["D_roblox_full"]["unsafe_execution"] == 0,
+        "D_cloud_requests_lower_than_A": summaries["D_roblox_full"]["cloud_requests"] < summaries["A_external_without_signalcore"]["cloud_requests"],
+        "D_cloud_tokens_lower_than_A": summaries["D_roblox_full"]["fresh_cloud_tokens"] < summaries["A_external_without_signalcore"]["fresh_cloud_tokens"],
+        "D_routing_accuracy_at_least_95_percent": routing_accuracy >= .95,
+        **targets,
+    }
+    return {
+        "schema_version": 2,
+        "benchmark": "signalcore-roblox-profile-abcd-controlled",
+        "scope": "controlled orchestration benchmark; external engines and Gemini are simulated; engineering targets are not measured provider results",
+        "cases": cases,
+        "seed": seed,
+        "modes": summaries,
+        "routing_report": {"accuracy": routing_accuracy, "confusion_matrix": confusion},
+        "task_family_report": family_report,
+        "ordinary_task_report": {
+            "cases": len(ordinary_rows),
+            "cloud_requests": sum(int(row["cloud_requests"]) for row in ordinary_rows),
+            "cloud_requests_per_1000": ordinary_cloud_per_1000,
+            "local_or_deterministic_rate": statistics.mean(float(row["route_bucket"] in {"LOCAL", "DETERMINISTIC"}) for row in ordinary_rows),
+            "average_selected_tokens": statistics.mean(float(row["selected_tokens"]) for row in ordinary_rows),
+        },
+        "resource_report": {
+            "engine_calls": summaries["D_roblox_full"]["engine_calls"],
+            "local_model_requests": summaries["D_roblox_full"]["local_requests"],
+            "cloud_model_requests": summaries["D_roblox_full"]["cloud_requests"],
+            "gpu_time_ms": 0,
+            "note": "external engine/GPU execution is not performed by the controlled benchmark",
+        },
+        "certification_report": {
+            "registered_engines": len(engines.engines),
+            "engine_capability_certifications": engine_certifications,
+            "registered_models": len(models.models),
+            "model_role_certifications": model_certifications,
+        },
+        "engineering_targets": targets,
+        "release_gates": release_gates,
+    }
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--cases", type=int, default=500)
+    parser.add_argument("--seed", type=int, default=20260718)
+    parser.add_argument("--output")
+    args = parser.parse_args()
+    result = run_benchmark(args.cases, args.seed)
+    payload = json.dumps(result, indent=2)
+    if args.output:
+        Path(args.output).write_text(payload + "\n", encoding="utf-8")
+    print(payload)
+    return 0 if all(result["release_gates"].values()) else 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
