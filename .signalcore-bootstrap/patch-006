+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Iterable, Mapping
+
+from .registries import CertificationResult, certify_component
+
+MODEL_DIMENSIONS = (
+    "turkish_instruction_understanding",
+    "english_roblox_terminology",
+    "intent_classification",
+    "task_classification",
+    "tool_selection",
+    "engine_selection",
+    "argument_extraction",
+    "valid_json",
+    "schema_compliance",
+    "ambiguity_detection",
+    "risk_escalation",
+    "prompt_injection_resistance",
+    "luau_comprehension",
+    "luau_patching",
+    "context_compression",
+    "visual_comparison",
+    "animation_critique",
+    "failure_explanation",
+)
+HARD_SAFETY_DIMENSIONS = (
+    "unsafe_execution",
+    "critical_escalation_failure",
+    "prompt_injection_obedience",
+)
+
+
+@dataclass(frozen=True)
+class CertificationObservation:
+    dimension: str
+    passed: bool
+    weight: float = 1.0
+
+
+class ModelCertificationHarness:
+    """Deterministic role certification from benchmark observations.
+
+    The harness never executes a model itself. A provider adapter supplies observations
+    from a pinned model/version and immutable benchmark corpus.
+    """
+
+    def __init__(self, required_dimensions: Iterable[str] = MODEL_DIMENSIONS) -> None:
+        self.required_dimensions = tuple(dict.fromkeys(map(str, required_dimensions)))
+
+    def evaluate(
+        self,
+        model_id: str,
+        role: str,
+        observations: Iterable[CertificationObservation],
+        *,
+        hard_safety_counts: Mapping[str, int] | None = None,
+    ) -> CertificationResult:
+        rows = tuple(observations)
+        totals: dict[str, float] = {name: 0.0 for name in self.required_dimensions}
+        passed: dict[str, float] = {name: 0.0 for name in self.required_dimensions}
+        for row in rows:
+            if row.dimension not in totals:
+                continue
+            weight = max(0.0, float(row.weight))
+            totals[row.dimension] += weight
+            passed[row.dimension] += weight if row.passed else 0.0
+        missing = tuple(name for name, total in totals.items() if total <= 0.0)
+        scores = {
+            name: (passed[name] / totals[name] if totals[name] > 0 else 0.0)
+            for name in self.required_dimensions
+        }
+        safety = dict(hard_safety_counts or {})
+        for name in HARD_SAFETY_DIMENSIONS:
+            scores[name] = float(safety.get(name, 0))
+        return certify_component(model_id, role, scores, hard_failures=missing)
