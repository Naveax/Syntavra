{
  "$id": "https://syntavra.dev/schemas/external-benchmark-receipt-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "arm": {
      "enum": ["baseline", "syntavra", "token-savior", "context-mode", "headroom", "volt-lcm", "recursive"]
    },
    "cached_input_tokens": {"minimum": 0, "type": "integer"},
    "cost_usd": {"minimum": 0, "type": "number"},
    "dataset_version": {"minLength": 1, "type": "string"},
    "environment_image_digest": {"pattern": "^sha256:[0-9a-f]{64}$", "type": "string"},
    "harness_commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "input_tokens": {"minimum": 0, "type": "integer"},
    "metadata": {"type": "object"},
    "model": {"minLength": 1, "type": "string"},
    "model_config_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "output_tokens": {"minimum": 0, "type": "integer"},
    "provider": {"minLength": 1, "type": "string"},
    "quality_score": {"maximum": 1, "minimum": 0, "type": "number"},
    "raw_provider_receipt_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "receipt_id": {"minLength": 1, "type": "string"},
    "recursive_calls": {"minimum": 0, "type": "integer"},
    "repetition": {"minimum": 1, "type": "integer"},
    "repository_commit": {"pattern": "^$|^[0-9a-f]{40}$", "type": "string"},
    "result_artifact_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "success": {"type": "boolean"},
    "suite_id": {
      "enum": ["swe-bench", "oolong", "longbench-v2", "infinitebench", "recursive-long-context"]
    },
    "synthetic": {"type": "boolean"},
    "task_id": {"minLength": 1, "type": "string"},
    "verifier_commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "wall_time_ms": {"minimum": 0, "type": "number"}
  },
  "required": [
    "receipt_id", "suite_id", "task_id", "arm", "repetition", "dataset_version",
    "harness_commit", "verifier_commit", "environment_image_digest", "repository_commit",
    "provider", "model", "model_config_hash", "result_artifact_hash",
    "raw_provider_receipt_hash", "quality_score", "success", "input_tokens",
    "cached_input_tokens", "output_tokens", "cost_usd", "wall_time_ms",
    "recursive_calls", "synthetic"
  ],
  "title": "Syntavra External Benchmark Receipt",
  "type": "object"
}
