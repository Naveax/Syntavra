{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntavra.dev/schemas/competitive-runtime-receipt-v1.json",
  "title": "Syntavra Unified AI Engineering Platform Receipt",
  "type": "object",
  "required": ["version", "channel", "component", "operation", "input_hash", "output_hash", "wall_time_ms", "exact_recovery"],
  "properties": {
    "version": {"const": "0.0.1"},
    "channel": {"const": "pre-release"},
    "component": {"enum": ["context", "firewall", "artifact", "graph", "memory", "security", "gateway", "adapter", "agent"]},
    "operation": {"type": "string", "minLength": 1},
    "input_hash": {"type": "string", "minLength": 32},
    "output_hash": {"type": "string", "minLength": 32},
    "wall_time_ms": {"type": "number", "minimum": 0},
    "exact_recovery": {"type": "boolean"},
    "metadata": {"type": "object"},
    "external_claim": {"const": false}
  },
  "additionalProperties": false
}
