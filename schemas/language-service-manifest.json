{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntavra.dev/schemas/language-service-manifest.json",
  "title": "Syntavra Sandboxed Language Service Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "languages", "command", "executable_sha256", "capabilities"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]{0,127}$"},
    "languages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]{0,127}$"}
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"type": "string", "minLength": 1, "maxLength": 8192, "pattern": "^[^\\u0000]+$"}
    },
    "executable_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "lexical", "syntax", "semantic", "definitions", "references",
          "implementations", "types", "call-hierarchy", "diagnostics",
          "rename", "code-actions"
        ]
      }
    },
    "timeout_seconds": {"type": "number", "minimum": 0.1, "maximum": 600, "default": 30},
    "max_output_bytes": {"type": "integer", "minimum": 1024, "maximum": 134217728, "default": 8388608},
    "max_nodes": {"type": "integer", "minimum": 1, "maximum": 2000000, "default": 250000},
    "max_edges": {"type": "integer", "minimum": 1, "maximum": 8000000, "default": 1000000},
    "strict_native": {"type": "boolean", "default": true}
  }
}
