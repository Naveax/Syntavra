{
  "$id": "https://syntavra.dev/schemas/provider-usage-receipt-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "arm": {
      "enum": [
        "baseline",
        "syntavra",
        "token-savior",
        "context-mode",
        "headroom",
        "volt-lcm"
      ]
    },
    "cached_input_tokens": {
      "minimum": 0,
      "type": "integer"
    },
    "cost_usd": {
      "minimum": 0,
      "type": "number"
    },
    "input_tokens": {
      "minimum": 0,
      "type": "integer"
    },
    "integration_id": {
      "minLength": 1,
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "model": {
      "minLength": 1,
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "type": "string"
    },
    "output_tokens": {
      "minimum": 0,
      "type": "integer"
    },
    "provider": {
      "minLength": 1,
      "type": "string"
    },
    "quality_score": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "raw_usage_hash": {
      "minLength": 32,
      "type": "string"
    },
    "receipt_id": {
      "minLength": 1,
      "type": "string"
    },
    "repetition": {
      "minimum": 1,
      "type": "integer"
    },
    "repository_hash": {
      "minLength": 16,
      "type": "string"
    },
    "request_id": {
      "minLength": 1,
      "type": "string"
    },
    "session_id": {
      "minLength": 1,
      "type": "string"
    },
    "success": {
      "type": "boolean"
    },
    "synthetic": {
      "type": "boolean"
    },
    "task_id": {
      "minLength": 1,
      "type": "string"
    },
    "wall_time_ms": {
      "minimum": 0,
      "type": "number"
    },
    "workload": {
      "enum": [
        "coding-agent",
        "repository-task",
        "swe-bench",
        "oolong-long-context",
        "session-continuity",
        "tool-routing"
      ]
    }
  },
  "required": [
    "receipt_id",
    "provider",
    "model",
    "request_id",
    "session_id",
    "repository_hash",
    "integration_id",
    "observed_at",
    "wall_time_ms",
    "input_tokens",
    "cached_input_tokens",
    "output_tokens",
    "cost_usd",
    "quality_score",
    "success",
    "synthetic",
    "raw_usage_hash",
    "workload",
    "arm",
    "task_id",
    "repetition"
  ],
  "title": "Syntavra Provider Usage Receipt",
  "type": "object"
}
