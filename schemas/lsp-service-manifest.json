{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntavra.dev/schemas/lsp-service-manifest.json",
  "title": "Syntavra Generic LSP Service Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "languages", "server_command", "server_executable_sha256"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]{0,127}$"},
    "languages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]{0,127}$"}
    },
    "server_command": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"type": "string", "minLength": 1, "maxLength": 8192, "pattern": "^[^\\u0000]+$"}
    },
    "server_executable_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "initialization_options": {"type": "object", "maxProperties": 10000, "default": {}},
    "timeout_seconds": {"type": "number", "minimum": 0.1, "maximum": 600, "default": 30},
    "max_message_bytes": {"type": "integer", "minimum": 1024, "maximum": 134217728, "default": 16777216},
    "max_output_bytes": {"type": "integer", "minimum": 1024, "maximum": 134217728, "default": 16777216},
    "strict_native": {"type": "boolean", "default": true}
  }
}
