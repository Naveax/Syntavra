{
  "$id": "https://syntavra.dev/schemas/product-maturity-evidence-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "distributions": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "channel_name": {"minLength": 1, "type": "string"},
          "downloads": {"minimum": 0, "type": "integer"},
          "observed_at": {"format": "date-time", "type": "string"},
          "package_name": {"minLength": 1, "type": "string"},
          "receipt_id": {"minLength": 1, "type": "string"},
          "source_verified": {"type": "boolean"},
          "synthetic": {"type": "boolean"},
          "unique_installations": {"minimum": 0, "type": "integer"},
          "version": {"const": "0.0.1"}
        },
        "required": [
          "receipt_id",
          "observed_at",
          "channel_name",
          "package_name",
          "version",
          "downloads",
          "unique_installations",
          "source_verified",
          "synthetic"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "onboarding": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "channel": {"const": "pre-release"},
          "doctor_passed": {"type": "boolean"},
          "install_wall_time_ms": {"minimum": 0, "type": "number"},
          "integration_id": {"minLength": 1, "type": "string"},
          "observed_at": {"format": "date-time", "type": "string"},
          "operating_system": {"minLength": 1, "type": "string"},
          "receipt_id": {"minLength": 1, "type": "string"},
          "repository_hash": {"minLength": 16, "type": "string"},
          "rollback_verified": {"type": "boolean"},
          "success": {"type": "boolean"},
          "synthetic": {"type": "boolean"},
          "user_hash": {"minLength": 16, "type": "string"},
          "version": {"const": "0.0.1"}
        },
        "required": [
          "receipt_id",
          "observed_at",
          "user_hash",
          "repository_hash",
          "integration_id",
          "operating_system",
          "install_wall_time_ms",
          "success",
          "rollback_verified",
          "doctor_passed",
          "synthetic",
          "version",
          "channel"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "releases": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "artifact_id": {"minLength": 1, "type": "string"},
          "channel": {"const": "pre-release"},
          "provenance": {"type": "boolean"},
          "published_at": {"format": "date-time", "type": "string"},
          "receipt_id": {"minLength": 1, "type": "string"},
          "signed": {"type": "boolean"},
          "source_verified": {"type": "boolean"},
          "synthetic": {"type": "boolean"},
          "version": {"const": "0.0.1"}
        },
        "required": [
          "receipt_id",
          "published_at",
          "artifact_id",
          "version",
          "channel",
          "signed",
          "provenance",
          "source_verified",
          "synthetic"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": ["onboarding", "distributions", "releases"],
  "title": "Syntavra External Product Maturity Evidence",
  "type": "object"
}
