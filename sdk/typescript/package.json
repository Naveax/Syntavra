{
  "name": "@signalcore/client",
  "version": "0.6.0",
  "description": "Typed, credential-isolated client for SignalCore Unified Production Core",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "tsconfig.json"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "sideEffects": false,
  "engines": {"node": ">=18"},
  "publishConfig": {"provenance": true, "access": "public"},
  "license": "MIT"
}
