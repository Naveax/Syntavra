{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalcore.dev/schemas/roblox-task-state-v2.json",
  "title": "RobloxTaskState V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "session_id", "place_id", "project_id", "project_fingerprint", "studio_process_id", "intent", "requested_capabilities", "authorized_capabilities", "evidence_requirements", "risk_class", "privacy_class", "execution_constraints", "token_budget", "request_budget", "transfer_budget", "gpu_budget", "wall_time_budget", "required_validators", "rollback_requirements", "completion_conditions"],
  "properties": {
    "schema_version": {"const": 2},
    "task_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "session_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "place_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "project_fingerprint": {"type": "string", "minLength": 16, "maxLength": 256},
    "studio_process_id": {"type": "integer", "minimum": 1},
    "intent": {"type": "string", "minLength": 1, "maxLength": 4096},
    "requested_capabilities": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string"}},
    "authorized_capabilities": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string"}},
    "evidence_requirements": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string"}},
    "risk_class": {"enum": ["R0", "R1", "R2", "R3", "R4", "R5"]},
    "privacy_class": {"enum": ["PUBLIC", "PROJECT", "SENSITIVE", "LOCAL_ONLY"]}
  }
}
